# Sears Home Services — env contract (copy to .env and fill in)
# See specs/constitution/tech-stack.md → Secrets.

# --- Agent LLM (DeepSeek, direct via LlamaIndex function calling) ---
DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat   (deepseek-reasoner unsupported: no function calling)
# LLM_PROVIDER=deepseek          (set to "openai" to fall back to gpt-4o)

# --- OpenAI (TTS, STT, vision, DeepEval judge) ---
OPENAI_API_KEY=sk-...

# --- Database ---
# Local Compose: postgresql://postgres:postgres@db:5432/sears
# Hosted (Neon): pooled string (-pooler host) for the app, direct string for migrations.
DATABASE_URL=postgresql://postgres:postgres@db:5432/sears
DATABASE_URL_DIRECT=postgresql://postgres:postgres@db:5432/sears

# --- App ---
# Frontend base URL used in emailed upload links (Tier 3)
APP_BASE_URL=http://localhost:3000
# cloudflare | smtp | console (console = offline demo, prints emails to logs)
EMAIL_BACKEND=console
# Cloudflare Email Service (Tier 3): API token + verified sender
CF_EMAIL_API_TOKEN=
EMAIL_FROM=
# Reserved for signed upload tokens (unused while tokens are DB-backed)
UPLOAD_TOKEN_SECRET=

# --- Twilio (Phase 5, telephony) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+13186468479
# Public host serving /twilio/voice and /ws/twilio (Cloudflare URL, or ngrok in dev)
PUBLIC_HOST=
NGROK_AUTHTOKEN=
