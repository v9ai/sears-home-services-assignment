# Sears Home Services — env contract (copy to .env and fill in)
# See specs/constitution/tech-stack.md → Secrets.
#
# MINIMUMS:
#   Local demo (text/eval — /healthz, upload page, transcript replay): OPENAI_API_KEY only.
#   Live phone call with default providers (STT=deepgram, TTS=cartesia): additionally set
#     TWILIO_AUTH_TOKEN, DEEPGRAM_API_KEY, CARTESIA_API_KEY, CARTESIA_VOICE_ID
#     (or switch STT_PROVIDER=openai / TTS_PROVIDER=openai to stay one-key).

# --- Agent LLM (DeepSeek, direct via LlamaIndex function calling) ---
DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat   (deepseek-reasoner unsupported: no function calling)
LLM_PROVIDER=openai
# Demo-day default swapped to OpenAI gpt-4o (user directive 2026-07-08; latency
# P2-2 — full-turn 7.5s vs 11.8s; note first-sentence was slower in the A/B).
# Unset (or =deepseek) returns to the DeepSeek code default.

# --- DeepEval judge (defaults to DeepSeek; evals/thresholds.py) ---
# EVAL_JUDGE_PROVIDER=deepseek     (set to "openai" to judge with gpt-4o instead)
# EVAL_JUDGE_MODEL=deepseek-chat   (or gpt-4o when EVAL_JUDGE_PROVIDER=openai)

# --- OpenAI (TTS, STT, vision; judge only when EVAL_JUDGE_PROVIDER=openai) ---
OPENAI_API_KEY=sk-...
OPENAI_LLM_MODEL=gpt-4.1-mini
# Fastest qualified model, measured 2026-07-08 (latency spec P2-2 sweep, N=3):
# 4.1-mini 4.29s first sentence 3/3 tools-correct; 4o 6.16s; 4.1-nano 1.96s but
# skipped tools 2/3 (disqualified); gpt-5-mini/nano 28-41s (reasoning tokens).
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_VISION_MODEL=gpt-4o

# --- Database ---
# In-container the compose app service pins its own DATABASE_URL (db:5432); this value
# is for HOST-side runs (pytest, alembic, make dev). The compose db publishes on 5433
# to avoid clashing with a Homebrew/system Postgres on 5432.
# Hosted (Neon): pooled string (-pooler host) for the app, direct string for
# migrations — libpq params (sslmode/channel_binding) are auto-translated for asyncpg.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/sears
DATABASE_URL_DIRECT=postgresql://postgres:postgres@localhost:5433/sears

# --- App ---
# Public base URL used in emailed upload links (Tier 3) — the backend serves the
# upload page itself at GET /upload/{token}
APP_BASE_URL=http://localhost:8000
# cloudflare | smtp | console (console = offline demo, prints emails to logs)
EMAIL_BACKEND=console
# Cloudflare Email Service (Tier 3): account id + API token + verified sender
CF_ACCOUNT_ID=
CF_EMAIL_API_TOKEN=
EMAIL_FROM=
# Override the Email Sending endpoint (defaults to
# https://api.cloudflare.com/client/v4/accounts/{CF_ACCOUNT_ID}/email/sending/send)
# CF_EMAIL_API_URL=
# SMTP fallback (only if EMAIL_BACKEND=smtp; port 465 = implicit TLS, else STARTTLS)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# Upload storage dir inside the app container (Docker named volume mounts here)
# UPLOAD_DIR=data/uploads
# Call recording storage dir inside the app container (Docker named volume mounts
# here) — specs/features/2026-07-08-call-recording-replay
# RECORDINGS_DIR=data/recordings
# On-demand TTS re-synthesis for replay turns with no stored audio (default off —
# no surprise API spend); not implemented in this pass, reserved for later
# REPLAY_TTS_FALLBACK=false
# Optional token gating the recordings UI/API. When set, /recordings and /api/recordings
# require this token (Authorization: Bearer <token> or ?token=<token>); when unset the
# endpoints are open (demo default). Implemented in app/recordings/.
# RECORDINGS_ACCESS_TOKEN=
# Reserved for signed upload tokens (unused while tokens are DB-backed)
UPLOAD_TOKEN_SECRET=

# --- Twilio (Phase 5, telephony) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+13186468479
# Public host serving /twilio/voice and /ws/twilio (Cloudflare URL, or ngrok in dev)
PUBLIC_HOST=
NGROK_AUTHTOKEN=
# Native Twilio call recording (<Start><Recording>, dual channel) — default on;
# set to false to disable (docs/twilio-webhook-setup.md "Native call recording")
# TWILIO_CALL_RECORDING_ENABLED=true
# App-side full-call recording via Pipecat's AudioBufferProcessor (stereo: caller left / bot
# right), saved to {RECORDINGS_DIR}/{session_id}/call.wav and shown in the recordings UI —
# default on; set to false to disable (app/voice/recording.py).
# VOICE_RECORDING_ENABLED=true

# --- Pipecat voice pipeline (the phone channel; app/voice) ---
# The /ws/twilio Media Streams transport is a Pipecat pipeline: transport → STT → LLM →
# TTS. Providers are swappable via *_PROVIDER; keys are read from env. See app/voice/README.md.
#
# STT: deepgram (default, streaming, low-latency — finalizes at end-of-speech) | openai | cartesia
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=                 # required when STT_PROVIDER=deepgram (or TTS_PROVIDER=deepgram)
# OPENAI_STT_MODEL=gpt-4o-transcribe   # used when STT_PROVIDER=openai (buffered; reuses OPENAI_API_KEY)
# CARTESIA_STT_MODEL=ink-whisper       # used when STT_PROVIDER=cartesia (reuses CARTESIA_API_KEY below)
# STT language pins — the agent is English-only by design (specs/constitution/mission.md
# non-goals), and Whisper-family models hallucinate foreign languages on short/near-silent
# clips (observed live 2026-07-09 as an Arabic turn). "" omits the hint on that provider.
# DEEPGRAM_STT_LANGUAGE=en-US      # Deepgram takes BCP-47
# OPENAI_STT_LANGUAGE=en           # ISO-639-1
# CARTESIA_STT_LANGUAGE=en         # ISO-639-1
#
# LLM: openai (default) | deepseek (matches the LlamaIndex agent)
# Uses OPENAI_API_KEY / DEEPSEEK_API_KEY above; LLM_PROVIDER above selects the family.
VOICE_LLM_MODEL=gpt-4.1-mini     # decoupled from OPENAI_LLM_MODEL; default = P2-2 sweep winner (f5, loop-v2 i10)
#
# TTS: cartesia (default, sonic-3.5 — lowest first-audio latency) | openai (gpt-4o-mini-tts) | deepgram (Aura-2)
TTS_PROVIDER=cartesia
# WEB channel dynamic-sentence TTS (chat page): cartesia (default since 2026-07-10 —
# measured TTFB p50 223ms vs OpenAI 696ms; pcm only, mp3 always uses OpenAI) | openai
# WEB_TTS_PROVIDER=cartesia
CARTESIA_API_KEY=                 # required by default (TTS_PROVIDER=cartesia, or STT_PROVIDER=cartesia)
CARTESIA_VOICE_ID=                # required when TTS_PROVIDER=cartesia
# CARTESIA_TTS_MODEL=sonic-3.5
# CARTESIA_TTS_LANGUAGE=en         # English-only line; keeps sonic from mirroring a non-English slip
# OPENAI_TTS_VOICE=alloy
# DEEPGRAM_AURA_VOICE=aura-2-thalia-en   # used when TTS_PROVIDER=deepgram
#
# VAD endpointing: silence (seconds) after the caller stops before the turn ends. Lower = less
# dead air before the bot replies; too low cuts callers off mid-sentence. Pipecat default ~0.8;
# code default 0.5; safe floor 0.4 (app/latency/budgets.py — below it callers get cut off).
# VAD_STOP_SECS=0.5
#
# Filler audio (perceived-latency bridge, app/voice/processors.FillerProcessor): if the LLM
# hasn't produced speakable text within FILLER_DELAY_MS of the caller finishing, speak the
# shared "Let me check that for you." line instead of dead air. Off by default in code (the
# hermetic latency tests measure the real eos->first-audio gap); enable per-deployment here.
# FILLER_ENABLED=1
# FILLER_DELAY_MS=1000
#
# Barge-in echo guard: words a caller must get transcribed before interrupting the speaking
# bot (a PSTN leg has no echo cancellation, so the bot's own TTS echo otherwise trips VAD and
# stutters the reply — docs/local-twilio-run.md). 0 disables (raw Pipecat defaults).
# VOICE_BARGEIN_MIN_WORDS=3
# Echo tail: the bot's LAST words echo back a few hundred ms after it stops, so the word bar
# stays up this long past bot speech (app/voice/turn_guard.py). 0 = plain min-words guard.
# VOICE_BARGEIN_TAIL_MS=400
# Outbound media framing in 10 ms units: 2 (default) = Twilio-idiomatic 20 ms/160-byte µ-law
# frames; 4 = pipecat's coarser 40 ms default (app/voice/bot.py::_build_transport_params).
# VOICE_OUT_10MS_CHUNKS=2
#
# Appliance-library RAG tool (retrieval-only, off by default — same as the LlamaIndex build).
# Set to 1 to register search_appliance_library; requires `python scripts/ingest_library.py`.
# LIBRARY_RAG_ENABLED=0
# QDRANT_PATH=data/qdrant
# EMBED_MODEL=BAAI/bge-small-en-v1.5
